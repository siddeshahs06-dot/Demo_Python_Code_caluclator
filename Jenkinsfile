pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code...'
            }
        }

    stages {
        stage('Checkout') {
            steps {
                bat 'python3 --version'
            }
        }

        stage('hello') {
            steps {
                bat 'python3 hello.py'
            }
        }

    }
}
